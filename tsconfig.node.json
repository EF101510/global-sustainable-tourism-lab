{
  "compilerOptions": {
    "composite": true,
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "strict": true,
    "outDir": "./node_modules/.cache/tsbuildinfo",
    "types": ["node"]
  },
  "include": ["vite.config.ts", "src/server/**/*.ts", "api/**/*.ts"]
}
