{
  "compilerOptions": {
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "strict": true,
    "noEmit": true,
    "types": ["node", "@cloudflare/workers-types"]
  },
  "include": [
    "vite.config.ts",
    "src/server/**/*.ts",
    "src/types/**/*.ts",
    "src/data/**/*.ts",
    "functions/**/*.ts"
  ]
}
